{
  "name": "build-hotspot-analyzer",
  "displayName": "Build Hotspot Analyzer",
  "description": "C/C++ build performance analysis and optimization suggestions via LSP",
  "version": "0.1.0",
  "publisher": "build-hotspot-analyzer",
  "author": "Gregorian Rayne",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/gregorian-09/build-hotspot-analyzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/gregorian-09/build-hotspot-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/gregorian-09/build-hotspot-analyzer/issues"
  },
  "files": [
    "out/**",
    "media/**",
    "README.md",
    "LICENSE.txt",
    "package.json",
    "tsconfig.json"
  ],
  "galleryBanner": {
    "color": "#10161c",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "c++",
    "c",
    "build",
    "optimization",
    "performance",
    "lsp",
    "compile",
    "tooling"
  ],
  "activationEvents": [
    "onLanguage:cpp",
    "onLanguage:c",
    "workspaceContains:**/CMakeLists.txt",
    "workspaceContains:**/Makefile",
    "workspaceContains:**/meson.build"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Build Hotspot Analyzer",
      "properties": {
        "buildHotspotAnalyzer.serverPath": {
          "type": "string",
          "default": "bha-lsp",
          "description": "Path to the bha-lsp executable"
        },
        "buildHotspotAnalyzer.autoAnalyze": {
          "type": "boolean",
          "default": false,
          "description": "Automatically analyze project on startup"
        },
        "buildHotspotAnalyzer.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the BHA language server"
        }
      }
    },
    "commands": [
      {
        "command": "buildHotspotAnalyzer.recordBuildTraces",
        "title": "BHA: Record Build Traces"
      },
      {
        "command": "buildHotspotAnalyzer.recordBuildTracesAdvanced",
        "title": "BHA: Record Build Traces (Advanced)"
      },
      {
        "command": "buildHotspotAnalyzer.analyzeProject",
        "title": "BHA: Analyze Build Performance"
      },
      {
        "command": "buildHotspotAnalyzer.showSuggestions",
        "title": "BHA: Show Suggestions"
      },
      {
        "command": "buildHotspotAnalyzer.applySuggestion",
        "title": "BHA: Apply Suggestion"
      },
      {
        "command": "buildHotspotAnalyzer.applyAllSuggestions",
        "title": "BHA: Apply All Suggestions"
      },
      {
        "command": "buildHotspotAnalyzer.revertChanges",
        "title": "BHA: Revert Changes"
      },
      {
        "command": "buildHotspotAnalyzer.restartServer",
        "title": "BHA: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && npm run bundle",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap",
    "compile": "npm run bundle",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0"
  }
}
